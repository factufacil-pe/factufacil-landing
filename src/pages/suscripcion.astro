---
/**
 * /suscripcion — signup / registration page.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { container } from '../infrastructure/container/Container';

const planesResult = await container.getAllPlanes.execute();
if (planesResult.isErr) throw new Error(`Planes error: ${planesResult.error}`);
const { planes } = planesResult.value;

const whatsapp = 'https://wa.me/51964979320';
---

<BaseLayout
  title="Suscribirse"
  description="Elige tu plan y comienza a usar FactuFacil hoy mismo. Facturación electrónica desde S/.45/mes."
>

  <!-- Page header -->
  <section class="bg-gradient-to-br from-brand-900 to-brand-800 py-16 text-white text-center">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold mb-4">Elige tu Plan</h1>
      <p class="text-lg text-brand-100">
        Comienza hoy con facturación electrónica y haz crecer tu negocio
      </p>
    </div>
  </section>

  <!-- Plan selector -->
  <section class="py-16 bg-gray-50">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2">
        {planes.map((plan) => (
          <div class={`rounded-2xl p-8 flex flex-col ${plan.isPopular ? 'bg-brand-800 text-white shadow-2xl ring-4 ring-brand-500/30' : 'bg-white border border-gray-200 shadow-sm'}`}>
            {plan.isPopular && (
              <span class="mb-4 self-start rounded-full bg-yellow-400 px-4 py-1 text-xs font-bold text-gray-900">
                MÁS POPULAR
              </span>
            )}
            <h2 class={`text-xl font-extrabold mb-1 ${plan.isPopular ? 'text-white' : 'text-gray-900'}`}>
              Plan {plan.name}
            </h2>
            <div class="mb-5">
              <span class={`text-3xl font-extrabold ${plan.isPopular ? 'text-white' : 'text-brand-800'}`}>
                S/.{plan.price}
              </span>
              <span class={`text-sm ${plan.isPopular ? 'text-brand-200' : 'text-gray-400'}`}>/mes</span>
              <p class={`text-xs mt-1 ${plan.isPopular ? 'text-brand-300' : 'text-gray-400'}`}>
                S/.{plan.yearlyPrice}/año
              </p>
            </div>
            <ul class="space-y-2 text-sm flex-1 mb-6">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class={`h-4 w-4 mt-0.5 flex-shrink-0 ${plan.isPopular ? 'text-yellow-300' : 'text-green-500'}`} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class={plan.isPopular ? 'text-brand-100' : 'text-gray-600'}>{f}</span>
                </li>
              ))}
            </ul>
            <a
              href={whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              class={`w-full rounded-xl py-3 text-center text-sm font-bold transition-colors ${plan.isPopular ? 'bg-yellow-400 text-gray-900 hover:bg-yellow-300' : 'bg-brand-700 text-white hover:bg-brand-800'}`}
            >
              Contratar Plan {plan.name}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact / Inquiry form section -->
  <section class="py-16 bg-white">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-extrabold text-gray-900 text-center mb-2">¿Tienes alguna pregunta?</h2>
      <p class="text-center text-gray-500 mb-8 text-sm">
        Completa el formulario o escríbenos por WhatsApp y un asesor te contactará.
      </p>

      <form class="space-y-5 rounded-2xl bg-gray-50 border border-gray-100 p-8 shadow-sm">
        <div>
          <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">Nombre completo</label>
          <input
            id="nombre"
            name="nombre"
            type="text"
            required
            placeholder="Tu nombre"
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Correo electrónico</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="tu@correo.com"
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
          />
        </div>
        <div>
          <label for="telefono" class="block text-sm font-medium text-gray-700 mb-1">Teléfono / WhatsApp</label>
          <input
            id="telefono"
            name="telefono"
            type="tel"
            placeholder="+51 9xx xxx xxx"
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
          />
        </div>
        <div>
          <label for="plan" class="block text-sm font-medium text-gray-700 mb-1">Plan de interés</label>
          <select
            id="plan"
            name="plan"
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
          >
            <option value="">Selecciona un plan</option>
            {planes.map((p) => (
              <option value={p.id}>Plan {p.name} — S/.{p.price}/mes</option>
            ))}
          </select>
        </div>
        <div>
          <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-1">Mensaje (opcional)</label>
          <textarea
            id="mensaje"
            name="mensaje"
            rows={3}
            placeholder="Cuéntanos sobre tu negocio..."
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 resize-none"
          ></textarea>
        </div>

        <a
          href={whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="flex w-full items-center justify-center gap-2 rounded-xl bg-brand-700 py-3.5 text-sm font-bold text-white hover:bg-brand-800 transition-colors"
        >
          Enviar por WhatsApp
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
      </form>
    </div>
  </section>

</BaseLayout>
